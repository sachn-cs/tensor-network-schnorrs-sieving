# Auto detect text files and perform LF normalization
* text=auto

# Rust sources
*.rs text diff=rust
*.toml text
*.lock text -diff

# Documentation
*.md text diff=markdown
*.txt text

# Shell scripts
*.sh text eol=lf

# Configuration files
*.yml text
*.yaml text
*.json text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Generated files
Cargo.lock -diff
